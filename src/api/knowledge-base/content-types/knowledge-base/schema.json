{
  "kind": "collectionType",
  "collectionName": "knowledge_bases",
  "info": {
    "singularName": "knowledge-base",
    "pluralName": "knowledge-bases",
    "displayName": "KnowledgeBase"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "symptoms": {
      "type": "blocks"
    },
    "theFix": {
      "type": "blocks"
    },
    "severity": {
      "type": "enumeration",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "mappedBy": "knowledge_bases"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "lastVerified": {
      "type": "date"
    },
    "related_articles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::knowledge-base.knowledge-base",
      "inversedBy": "knowledge_bases"
    },
    "knowledge_bases": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::knowledge-base.knowledge-base",
      "mappedBy": "related_articles"
    }
  }
}
